# Stokvel OS — Environment Variables
# Copy to .env and fill in values. App will NOT start without required vars.

# ── REQUIRED ──────────────────────────────────────────────
JWT_SECRET=          # Generate: python -c "import secrets; print(secrets.token_hex(32))"
DATABASE_URL=postgresql+asyncpg://user:pass@localhost:5432/stokvel_db
REDIS_URL=redis://localhost:6379/0

# ── AWS SES (email OTP) ──────────────────────────────────
AWS_REGION=af-south-1
AWS_ACCESS_KEY_ID=
AWS_SECRET_ACCESS_KEY=
SES_SENDER_EMAIL=noreply@stokvel.co.za

# ── OPTIONAL ──────────────────────────────────────────────
ENVIRONMENT=development
PORT=8000
OTP_EXPIRY_SECONDS=300
OTP_LENGTH=6
